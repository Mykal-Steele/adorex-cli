{
  "name": "adorex-app",
  "version": "1.0.0",
  "description": "Express + TypeScript + Prisma + SQLite application scaffolded with adorex-cli",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "engines": {
    "node": "^20.19 || ^22.12 || ^24.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.12.0",
    "prisma": "^7.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
